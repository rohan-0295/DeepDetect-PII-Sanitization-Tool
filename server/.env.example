# ─── DeepDetect Environment Configuration ────────────────────────────────────
# Copy this file to .env and fill in real values. Never commit .env to git!

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/deepdetect
# For Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/deepdetect

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING
JWT_EXPIRES_IN=8h

# ─── Hashing / Encryption ────────────────────────────────────────────────────
# Used for deterministic SHA-256 hashing mode
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HASH_SECRET=CHANGE_THIS_TO_A_RANDOM_32_CHAR_HEX_STRING
IP_SALT=CHANGE_THIS_FOR_IP_ANONYMIZATION

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Cloudmersive DLP API (Optional — high-accuracy AI detection) ─────────────
# Sign up at https://cloudmersive.com
CLOUDMERSIVE_API_KEY=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# ─── Email (SMTP) ──────────────────────────────────────────────────────────────
# Leave blank in development — emails print to console instead
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
EMAIL_FROM=DeepDetect <noreply@yourdomain.com>
